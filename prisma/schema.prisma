generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  phone          String          @unique
  email          String?         @unique
  passwordHash   String          @map("password_hash")
  pinHash        String?         @map("pin_hash")
  isActive       Boolean         @default(true) @map("is_active")
  lastLoginAt    DateTime?       @map("last_login_at")
  lastLoginIp    String?         @map("last_login_ip")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  cashRegisters  CashRegister[]
  creditPayments CreditPayment[]
  expenses       Expense[]
  purchases      Purchase[]
  refreshTokens  RefreshToken[]
  sales          Sale[]
  shopUsers      ShopUser[]
  stockMovements StockMovement[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Shop {
  id             Int             @id @default(autoincrement())
  ownerId        Int             @map("owner_id")
  name           String
  phone          String?
  address        String?
  city           String?
  logoUrl        String?         @map("logo_url")
  primaryColor   String          @default("#1B5E20") @map("primary_color")
  currency       String          @default("XOF")
  plan           Plan            @default(trial)
  trialEndsAt    DateTime?       @map("trial_ends_at")
  planExpiresAt  DateTime?       @map("plan_expires_at")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  cashRegisters  CashRegister[]
  categories     Category[]
  credits        Credit[]
  customers      Customer[]
  expenses       Expense[]
  invoices       Invoice[]
  products       Product[]
  purchases      Purchase[]
  sales          Sale[]
  shopUsers      ShopUser[]
  stockMovements StockMovement[]
  subscriptions  Subscription[]
  suppliers      Supplier[]

  @@map("shops")
}

model ShopUser {
  id        Int      @id @default(autoincrement())
  shopId    Int      @map("shop_id")
  userId    Int      @map("user_id")
  role      UserRole @default(seller)
  createdAt DateTime @default(now()) @map("created_at")
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([shopId])
  @@index([userId])
  @@map("shop_users")
}

model Category {
  id        Int       @id @default(autoincrement())
  shopId    Int       @map("shop_id")
  name      String
  icon      String?
  color     String?
  createdAt DateTime  @default(now()) @map("created_at")
  shop      Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([shopId])
  @@map("categories")
}

model Product {
  id             Int             @id @default(autoincrement())
  shopId         Int             @map("shop_id")
  categoryId     Int?            @map("category_id")
  name           String
  reference      String?
  unit           String          @default("pièce")
  buyPrice       Decimal         @default(0) @map("buy_price") @db.Decimal(12, 2)
  sellPrice      Decimal         @map("sell_price") @db.Decimal(12, 2)
  sellPriceGros  Decimal?        @map("sell_price_gros") @db.Decimal(12, 2)
  stockQty       Decimal         @default(0) @map("stock_qty") @db.Decimal(12, 3)
  stockAlert     Decimal         @default(5) @map("stock_alert") @db.Decimal(12, 3)
  photoUrl       String?         @map("photo_url")
  isActive       Boolean         @default(true) @map("is_active")
  deletedAt      DateTime?       @map("deleted_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  category       Category?       @relation(fields: [categoryId], references: [id])
  shop           Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
  stockMovements StockMovement[]

  @@index([shopId])
  @@index([shopId, isActive])
  @@index([shopId, categoryId])
  @@map("products")
}

model StockMovement {
  id            Int               @id @default(autoincrement())
  shopId        Int               @map("shop_id")
  productId     Int               @map("product_id")
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  unitPrice     Decimal?          @map("unit_price") @db.Decimal(12, 2)
  referenceType String?           @map("reference_type")
  referenceId   Int?              @map("reference_id")
  userId        Int               @map("user_id")
  note          String?
  createdAt     DateTime          @default(now()) @map("created_at")
  product       Product           @relation(fields: [productId], references: [id])
  shop          Shop              @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([shopId, productId])
  @@index([shopId, type])
  @@map("stock_movements")
}

model Customer {
  id            Int          @id @default(autoincrement())
  shopId        Int          @map("shop_id")
  name          String
  phone         String?
  type          CustomerType @default(individual)
  address       String?
  isVip         Boolean      @default(false) @map("is_vip")
  totalBought   Decimal      @default(0) @map("total_bought") @db.Decimal(14, 2)
  creditBalance Decimal      @default(0) @map("credit_balance") @db.Decimal(14, 2)
  deletedAt     DateTime?    @map("deleted_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  credits       Credit[]
  shop          Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoices      Invoice[]
  sales         Sale[]

  @@index([shopId])
  @@map("customers")
}

model Sale {
  id            Int           @id @default(autoincrement())
  shopId        Int           @map("shop_id")
  customerId    Int?          @map("customer_id")
  userId        Int           @map("user_id")
  reference     String        @unique
  totalAmount   Decimal       @map("total_amount") @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  netAmount     Decimal       @map("net_amount") @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  paidAmount    Decimal       @map("paid_amount") @db.Decimal(12, 2)
  creditAmount  Decimal       @default(0) @map("credit_amount") @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  credits       Credit[]
  invoices      Invoice[]
  items         SaleItem[]
  customer      Customer?     @relation(fields: [customerId], references: [id])
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([shopId, createdAt])
  @@index([shopId, userId])
  @@map("sales")
}

model SaleItem {
  id         Int     @id @default(autoincrement())
  saleId     Int     @map("sale_id")
  productId  Int     @map("product_id")
  quantity   Decimal @db.Decimal(12, 3)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)
  product    Product @relation(fields: [productId], references: [id])
  sale       Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_items")
}

model Credit {
  id              Int             @id @default(autoincrement())
  shopId          Int             @map("shop_id")
  customerId      Int             @map("customer_id")
  saleId          Int?            @map("sale_id")
  amountTotal     Decimal         @map("amount_total") @db.Decimal(12, 2)
  amountPaid      Decimal         @default(0) @map("amount_paid") @db.Decimal(12, 2)
  amountRemaining Decimal         @map("amount_remaining") @db.Decimal(12, 2)
  dueDate         DateTime?       @map("due_date") @db.Date
  status          CreditStatus    @default(open)
  notes           String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  payments        CreditPayment[]
  customer        Customer        @relation(fields: [customerId], references: [id])
  sale            Sale?           @relation(fields: [saleId], references: [id])
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, status])
  @@index([shopId, customerId])
  @@map("credits")
}

model CreditPayment {
  id            Int           @id @default(autoincrement())
  creditId      Int           @map("credit_id")
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @map("payment_method")
  userId        Int           @map("user_id")
  note          String?
  createdAt     DateTime      @default(now()) @map("created_at")
  credit        Credit        @relation(fields: [creditId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  @@index([creditId])
  @@map("credit_payments")
}

model CashRegister {
  id                Int                @id @default(autoincrement())
  shopId            Int                @map("shop_id")
  userId            Int                @map("user_id")
  date              DateTime           @db.Date
  openingAmount     Decimal            @map("opening_amount") @db.Decimal(12, 2)
  closingAmount     Decimal?           @map("closing_amount") @db.Decimal(12, 2)
  theoreticalAmount Decimal?           @map("theoretical_amount") @db.Decimal(12, 2)
  difference        Decimal?           @db.Decimal(12, 2)
  status            CashRegisterStatus @default(open)
  notes             String?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  shop              Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id])

  @@unique([shopId, date])
  @@index([shopId])
  @@map("cash_registers")
}

model Supplier {
  id          Int        @id @default(autoincrement())
  shopId      Int        @map("shop_id")
  name        String
  phone       String?
  address     String?
  debtBalance Decimal    @default(0) @map("debt_balance") @db.Decimal(14, 2)
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  purchases   Purchase[]
  shop        Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("suppliers")
}

model Purchase {
  id            Int            @id @default(autoincrement())
  shopId        Int            @map("shop_id")
  supplierId    Int?           @map("supplier_id")
  userId        Int            @map("user_id")
  reference     String         @unique
  totalAmount   Decimal        @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal        @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentMethod PaymentMethod  @map("payment_method")
  deliveryDate  DateTime?      @map("delivery_date") @db.Date
  notes         String?
  createdAt     DateTime       @default(now()) @map("created_at")
  items         PurchaseItem[]
  shop          Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  user          User           @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@map("purchases")
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int      @map("purchase_id")
  productId  Int      @map("product_id")
  quantity   Decimal  @db.Decimal(12, 3)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@map("purchase_items")
}

model Expense {
  id          Int             @id @default(autoincrement())
  shopId      Int             @map("shop_id")
  userId      Int             @map("user_id")
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(12, 2)
  description String?
  date        DateTime        @db.Date
  isRecurring Boolean         @default(false) @map("is_recurring")
  recurDay    Int?            @map("recur_day")
  createdAt   DateTime        @default(now()) @map("created_at")
  shop        Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])

  @@index([shopId])
  @@index([shopId, date])
  @@map("expenses")
}

model Invoice {
  id         Int           @id @default(autoincrement())
  shopId     Int           @map("shop_id")
  customerId Int?          @map("customer_id")
  saleId     Int?          @map("sale_id")
  reference  String        @unique
  type       InvoiceType   @default(invoice)
  status     InvoiceStatus @default(draft)
  amountHt   Decimal       @map("amount_ht") @db.Decimal(12, 2)
  tvaRate    Decimal       @default(0) @map("tva_rate") @db.Decimal(5, 2)
  amountTtc  Decimal       @map("amount_ttc") @db.Decimal(12, 2)
  pdfUrl     String?       @map("pdf_url")
  sentAt     DateTime?     @map("sent_at")
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  customer   Customer?     @relation(fields: [customerId], references: [id])
  sale       Sale?         @relation(fields: [saleId], references: [id])
  shop       Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("invoices")
}

model Subscription {
  id         Int      @id @default(autoincrement())
  shopId     Int      @map("shop_id")
  amount     Decimal  @db.Decimal(10, 2)
  paymentRef String?  @map("payment_ref")
  startsAt   DateTime @map("starts_at")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("subscriptions")
}

enum UserRole {
  owner
  seller
}

enum Plan {
  trial
  active
  expired
}

enum PaymentMethod {
  cash
  wave
  orange_money
  credit
  mixed
}

enum CreditStatus {
  open
  partial
  paid
  overdue
}

enum CashRegisterStatus {
  open
  closed
}

enum StockMovementType {
  sale
  purchase
  adjustment
  return
  loss
}

enum InvoiceType {
  invoice
  quote
  credit_note
}

enum InvoiceStatus {
  draft
  sent
  paid
  cancelled
}

enum ExpenseCategory {
  rent
  electricity
  water
  salary
  transport
  supplier
  other
}

enum CustomerType {
  individual
  professional
  btp
}
