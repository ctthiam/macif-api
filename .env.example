# Base de données PostgreSQL (Railway fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://USER:PASS@HOST:5432/macif_db?schema=public

# JWT — générer avec: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_THIS_LONG_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_ANOTHER_LONG_RANDOM_STRING_64_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Redis (Railway fournit REDIS_URL automatiquement)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (stockage fichiers)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=macif-files
R2_PUBLIC_URL=https://files.macif.sn

# PayDunya (Wave, Orange Money, Free Money)
# Mode test: https://app.paydunya.com/sandbox-api
# Mode live: https://app.paydunya.com/api
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# CORS
FRONTEND_URL=https://macif.vercel.app

# URL publique de cette API (pour les webhooks PayDunya)
API_URL=https://your-api.up.railway.app

# Serveur
PORT=4000
NODE_ENV=production
